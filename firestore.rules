rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Users Collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) 
        && incoming().uid == request.auth.uid
        && incoming().email == request.auth.token.email
        && incoming().role in ['Student', 'Teacher', 'Parent', 'Counsellor', 'Administrator']
        && incoming().displayName is string && incoming().displayName.size() <= 100
        && incoming().createdAt == request.time;
      
      allow update: if isOwner(userId)
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && incoming().role == existing().role
        && incoming().displayName is string && incoming().displayName.size() <= 100
        && incoming().createdAt == existing().createdAt;
    }

    // Assessments Collection
    match /assessments/{assessmentId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Teacher', 'Counsellor', 'Administrator']);
      
      allow create: if isSignedIn()
        && isValidId(assessmentId)
        && incoming().userId == request.auth.uid
        && incoming().gradeLevel in ['Grade 9', 'Grade 12', 'Undergraduate']
        && incoming().progress is int && incoming().progress >= 0 && incoming().progress <= 100
        && incoming().currentQuestionIndex is int && incoming().currentQuestionIndex >= 0
        && incoming().completed is bool
        && incoming().updatedAt == request.time;

      allow update: if isSignedIn()
        && (existing().userId == request.auth.uid)
        && incoming().userId == existing().userId
        && incoming().gradeLevel == existing().gradeLevel
        && incoming().progress is int && incoming().progress >= 0 && incoming().progress <= 100
        && incoming().currentQuestionIndex is int && incoming().currentQuestionIndex >= 0
        && incoming().completed is bool
        && incoming().updatedAt == request.time;

      allow delete: if isSignedIn() && (existing().userId == request.auth.uid);
    }
  }
}
